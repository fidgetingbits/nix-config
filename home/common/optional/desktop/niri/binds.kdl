gestures {
    hot-corners {
        off
    }
}
binds {
    // Show a list of important bindings.
    Super+Slash {
        show-hotkey-overlay
    }
    // Shutting up hotkey-overlay defaults. I don't have/use mod5
    Mod5+Up hotkey-overlay-title=null {
        move-column-to-workspace-up
    }
    Mod5+Down hotkey-overlay-title=null {
        move-column-to-workspace-down
    }
    Mod5+Left hotkey-overlay-title=null {
        focus-column-left
    }
    Mod5+Right hotkey-overlay-title=null {
        focus-column-right
    }
    Mod5+Q hotkey-overlay-title=null {
        quit
    }
    //
    // ========== Overview mode ==========
    //
    Super+O repeat=false {
        toggle-overview
    }
    //
    // ========== Monitor actions ==========
    //
    Super+Ctrl+h hotkey-overlay-title="Focus monitor left" {
        focus-monitor-left
    }
    Super+Ctrl+j hotkey-overlay-title="Focus monitor down" {
        focus-monitor-down
    }
    Super+Ctrl+k hotkey-overlay-title="Focus monitor up" {
        focus-monitor-up
    }
    Super+Ctrl+l hotkey-overlay-title="Focus monitor right" {
        focus-monitor-right
    }
    //
    // ========== Workspace actions ==========
    //
    // ========== Focus workspace ==========
    Super+1 {
        focus-workspace "1_dev"
    }
    Super+2 {
        focus-workspace "2_web"
    }
    Super+3 {
        focus-workspace 3
    }
    Super+4 {
        focus-workspace 4
    }
    Super+5 {
        focus-workspace 5
    }
    Super+6 {
        focus-workspace 6
    }
    Super+7 {
        focus-workspace 7
    }
    Super+8 {
        focus-workspace 8
    }
    Super+9 {
        focus-workspace 9
    }
    Super+0 {
        focus-workspace 0
    }
    Super+Y {
        focus-workspace "Y_qrs"
    }
    Super+Period hotkey-overlay-title="Focus workspace previous" {
        focus-workspace-previous
    }
    //
    // ========== Window and column actions ==========
    //
    Super+Shift+Q {
        close-window
    }
    // ========== Focus windows/columns ==========
    Super+Z {
        switch-focus-between-floating-and-tiling
    }
    Super+H {
        focus-column-or-monitor-left
    }
    Super+J {
        focus-window-or-workspace-down
    }
    Super+K {
        focus-window-or-workspace-up
    }
    Super+L {
        focus-column-or-monitor-right
    }
    // FIXME: Change
    Super+Home {
        focus-column-first
    }
    Super+End {
        focus-column-last
    }
    Super+C hotkey-overlay-title="Center column on screen" {
        center-column
    }
    Super+Ctrl+C hotkey-overlay-title="Center all fully visible columns on screen" {
        center-visible-columns
    }
    // ========== Move windows/columns ==========
    Super+Shift+1 {
        move-window-to-workspace "1_dev"
    }
    Super+Shift+2 {
        move-window-to-workspace "2_web"
    }
    Super+Shift+3 {
        move-window-to-workspace 3
    }
    Super+Shift+4 {
        move-window-to-workspace 4
    }
    Super+Shift+5 {
        move-window-to-workspace 5
    }
    Super+Shift+6 {
        move-window-to-workspace 6
    }
    Super+Shift+7 {
        move-window-to-workspace 7
    }
    Super+Shift+8 {
        move-window-to-workspace 8
    }
    Super+Shift+9 {
        move-window-to-workspace 9
    }
    Super+Shift+0 {
        move-window-to-workspace 0
    }
    Super+Shift+Y {
        move-window-to-workspace "Y_qrs"
    }
    Super+Shift+H {
        move-column-left
    }
    Super+Shift+J {
        move-window-down
    }
    Super+Shift+k {
        move-window-up
    }
    Super+Shift+L {
        move-column-right
    }
    Super+Semicolon hotkey-overlay-title="Move window to column left" {
        consume-or-expel-window-left
    }
    Super+Apostrophe hotkey-overlay-title="Move window to column right" {
        consume-or-expel-window-right
    }
    Super+Shift+BracketLeft hotkey-overlay-title="Move column to first" {
        move-column-to-first
    }
    Super+Shift+BracketRight hotkey-overlay-title="Move column to last" {
        move-column-to-last
    }
    Super+Ctrl+Shift+H hotkey-overlay-title="Move window to monitor left" {
        move-window-to-monitor-left
    }
    Super+Ctrl+Shift+J hotkey-overlay-title="Move window to monitor down" {
        move-window-to-monitor-down
    }
    Super+Ctrl+Shift+K hotkey-overlay-title="Move window to monitor up" {
        move-window-to-monitor-up
    }
    Super+Ctrl+Shift+L hotkey-overlay-title="Move window to monitor right" {
        move-window-to-monitor-right
    }
    // ========== Window Tabs ==========
    // Use `consume-or-expel-...` binds above to add/remove windows to a tabbed column
    Super+G hotkey-overlay-title="Toggle column tabs" {
        toggle-column-tabbed-display
    }
    // Toggle the focused column between normal and tabbed display    //
    // ========== Window and column size ==========
    //
    // Presets are defined in rules.kdl
    Super+R hotkey-overlay-title="Switch preset column width" {
        switch-preset-column-width
    }
    // Presets are defined in rules.kdl
    Super+Shift+R hotkey-overlay-title="Switch preset column height" {
        switch-preset-window-height
    }
    Super+F hotkey-overlay-title="Toggle fullscreen" {
        fullscreen-window
    }
    Super+Alt+F hotkey-overlay-title="Toggle windowed fullscreen" {
        toggle-windowed-fullscreen
    }
    Super+Shift+F hotkey-overlay-title="Toggle floating" {
        toggle-window-floating
    }
    Super+Ctrl+F hotkey-overlay-title="Maximize column width" {
        maximize-column
    }
    // Toggle maximized state of the focused column
    Super+Shift+Ctrl+F hotkey-overlay-title="Expand column to available width" {
        expand-column-to-available-width
    }
    Super+BracketLeft {
        set-column-width "-1"
    }
    Super+BracketRight {
        set-column-width "+1"
    }
    Super+Minus {
        set-window-height "-1"
    }
    Super+Plus {
        set-window-height "+1"
    }
    //
    // ========== System controls ==========
    //
    // ========== Brightness ==========
    XF86MonBrightnessUp allow-when-locked=true hotkey-overlay-title=null {
        // spawn "brightnessctl" "set" "0.01+"
        spawn "noctalia-shell" "ipc" "call" "brightness" "increase"
    }
    XF86MonBrightnessDown allow-when-locked=true hotkey-overlay-title=null {
        // spawn "brightnessctl" "set" "0.01-"
        spawn "noctalia-shell" "ipc" "call" "brightness" "decrease"
    }
    // ========== Media Control==========
    XF86AudioPlay allow-when-locked=true hotkey-overlay-title=null {
        // spawn "playerctl" "play-pause" "--ignore-player=firefox,chromium,brave"
        spawn "noctalia-shell" "ipc" "call" "media" "playPause"
    }
    XF86AudioStop allow-when-locked=true hotkey-overlay-title=null {
        // spawn "playerctl" "stop" "--ignore-player=firefox,chromium,brave"
        spawn "noctalia-shell" "ipc" "call" "media" "pause"
    }
    XF86AudioPrev allow-when-locked=true hotkey-overlay-title=null {
        // spawn "playerctl" "previous" "--ignore-player=firefox,chromium,brave"
        spawn "noctalia-shell" "ipc" "call" "media" "previous"
    }
    XF86AudioNext allow-when-locked=true hotkey-overlay-title=null {
        // spawn "playerctl" "next" "--ignore-player=firefox,chromium,brave"
        spawn "noctalia-shell" "ipc" "call" "media" "next"
    }
    XF86AudioRewind allow-when-locked=true hotkey-overlay-title=null {
        // spawn "playerctl" "position" "2-" "--ignore-player=firefox,chromium,brave"
        spawn "noctalia-shell" "ipc" "call" "media" "seekRelative" "-2"
    }
    XF86AudioForward allow-when-locked=true hotkey-overlay-title=null {
        // spawn "playerctl" "position" "2+" "--ignore-player=firefox,chromium,brave"
        spawn "noctalia-shell" "ipc" "call" "media" "seekRelative" "2"
    }
    // ========== Output audio control==========
    XF86AudioRaiseVolume allow-when-locked=true hotkey-overlay-title=null {
        // spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.05+"
        spawn "noctalia-shell" "ipc" "call" "volume" "increase"
    }
    XF86AudioLowerVolume allow-when-locked=true hotkey-overlay-title=null {
        // spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.05-"
        spawn "noctalia-shell" "ipc" "call" "volume" "decrease"
    }
    XF86AudioMute allow-when-locked=true hotkey-overlay-title=null {
        // spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"
        spawn "noctalia-shell" "ipc" "call" "volume" "muteOutput"
    }
    // ========== Input audio control==========
    Super+XF86AudioRaiseVolume allow-when-locked=true hotkey-overlay-title=null {
        // spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SOURCE@" "0.05+"
        spawn "noctalia-shell" "ipc" "call" "volume" "increaseInput"
    }
    Super+XF86AudioLowerVolume allow-when-locked=true hotkey-overlay-title=null {
        // spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SOURCE@" "0.05-"
        spawn "noctalia-shell" "ipc" "call" "volume" "decreaseInput"
    }
    Super+XF86AudioMute allow-when-locked=true hotkey-overlay-title=null {
        // spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle"
        spawn "noctalia-shell" "ipc" "call" "volume" "muteInput"
    }
    XF86AudioMicMute allow-when-locked=true hotkey-overlay-title=null {
        // spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle"
        spawn "noctalia-shell" "ipc" "call" "volume" "muteInput"
    }
    // ========== Screenshots ==========
    //
    // NOTE: see config.kdl for screenshot-path
    Print {
        screenshot
    }
    Super+Shift+P hotkey-overlay-title="Screenshot" {
        screenshot
    }
    // Super+Ctrl+Shift+P { screenshot write-to-disk=true; }
    // Super+Alt+P { screenshot show-pointer=false; }
    // Super+Ctrl+Alt+P { screenshot show-pointer=true; }
    //
    //
    // ========== Noctalia calls ==========
    //
    // NOTE: Session Menu is for hibernate, sleep, logout, power, etc
    Super+E hotkey-overlay-title="Session Menu" {
        spawn-sh "noctalia-shell ipc call sessionMenu toggle"
    }
    Super+Space hotkey-overlay-title="Launcher" {
        spawn-sh "noctalia-shell ipc call launcher toggle"
    }
    Super+Shift+Space hotkey-overlay-title="Command Launcher" {
        spawn-sh "noctalia-shell ipc call launcher command"
    }
    Super+Comma hotkey-overlay-title="Noctalia Settings" {
        spawn "spawn-noctalia-settings"
    }
    Super+Ctrl+x hotkey-overlay-title="Lock screen" {
        spawn-sh "noctalia-shell ipc call lockScreen lock"
    }
    Super+Ctrl+S hotkey-overlay-title="Suspend" {
        spawn-sh "noctalia-shell ipc call sessionMenu lockAndSuspend"
    }
    Super+Ctrl+M hotkey-overlay-title="System Monitor" {
        spawn-sh "noctalia-shell ipc call systemMonitor toggle"
    }
    Super+Tab hotkey-overlay-title="Window selector" {
        // spawn "rofi" "-show" "window"
        spawn-sh "noctalia-shell ipc call launcher windows"
    }
    // ========== Quick Launch ==========
    //
    Super+Shift+G hotkey-overlay-title="Open non-neovim terminal" {
        spawn "ghostty"
    }
    Super+V hotkey-overlay-title="Open neovide" {
        // From fidgetingvim flake
        spawn "nvim-neovide"
    }
    Super+Return hotkey-overlay-title="New neovide terminal" {
        spawn "nvim-neovide" "--" "-c" "term"
    }
    // Thunar
    Super+Ctrl+O hotkey-overlay-title="Spawn file explorer" {
        spawn "thunar"
    }
    //
    // ========== Clipboard ==========
    //
    Super+P hotkey-overlay-title="Clipboard" {
        // spawn "rofi-copyq"
        spawn-sh "noctalia-shell ipc call launcher clipboard"
    }
 // FIXME(niri): setup with copyq
	// Select from the clipboard.
	//Super+Shift+V { spawn "dash" "-c" "clipman pick -t CUSTOM -T 'fuzzel -d --no-icons --width 60'"; }
	// Clear the clipboard.
	//Super+Ctrl+V { spawn "dash" "-c" "clipman clear --all && dunstify 'Clipboard cleared.'"; }
	// Opan a permanent "clipboard" file.
	//Alt+Shift+V { spawn "dash" "-c" "$TERMINAL -e micro $HOME/Documents/Clipboard.txt"; }

	// Applications such as remote-desktop clients and software KVM switches may
	// request that niri stops processing the keyboard shortcuts defined here
	// so they may, for example, forward the key presses as-is to a remote machine.
	// It's a good idea to bind an escape hatch to toggle the inhibitor,
	// so a buggy application can't hold your session hostage.
	//
	// The allow-inhibiting=false property can be applied to other binds as well,
	// which ensures niri always processes them, even when an inhibitor is active.
	// Super+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
}
